{%- comment -%}
  LUME — História de scroll cinematográfica.
  4 camadas de movimento:
    0. prefers-reduced-motion  -> tudo estático (vence todas)
    1. mobile  -> CSS Scroll-Driven Animations (nativo, compositor)
    2. desktop -> GSAP + ScrollTrigger no .page-wrapper
    3. fallback-> IntersectionObserver (uma vez)
  Watchdog: se o JS não bootar em 3s, revela tudo.
{%- endcomment -%}

{%- assign buy = section.settings.buy_url | default: '/products/lume-smart-ring' -%}

<div id="lume-ss-{{ section.id }}" class="lss">
  <script>
    (function () {
      var r = document.getElementById('lume-ss-{{ section.id }}');
      if (!r) return;
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
      r.classList.add('lss--anim');
      window.__lssGuards = window.__lssGuards || {};
      window.__lssGuards['{{ section.id }}'] = setTimeout(function () { r.classList.remove('lss--anim'); }, 3000);
    })();
  </script>

  {%- for i in (1..6) -%}
    {%- assign idx = forloop.index -%}
    {%- capture kicker_key %}k{{ idx }}_kicker{% endcapture -%}
    {%- capture title_key %}k{{ idx }}_title{% endcapture -%}
    {%- capture text_key %}k{{ idx }}_text{% endcapture -%}
    {%- capture img_d %}lume-ss-{{ idx }}.jpg{% endcapture -%}
    {%- capture img_m %}lume-ss-{{ idx }}-mobile.jpg{% endcapture -%}

    <section class="lss__ch" data-ch="{{ idx }}">
      <div class="lss__media">
        <picture>
          <source media="(max-width: 749px)" srcset="{{ img_m | asset_url }}">
          <img src="{{ img_d | asset_url }}"
               alt="{{ section.settings[title_key] | escape }}"
               {% if idx == 1 %}loading="eager" fetchpriority="high"{% else %}loading="lazy"{% endif %}
               width="1800" height="1004">
        </picture>
      </div>
      <div class="lss__copy">
        <p class="lss__kicker">{{ section.settings[kicker_key] }}</p>
        <h2 class="lss__title">{{ section.settings[title_key] }}</h2>
        <p class="lss__text">{{ section.settings[text_key] }}</p>
        {%- if idx == 6 -%}
          <div class="lss__cta">
            <a class="lss__btn lss__btn--solid" href="{{ buy }}">{{ section.settings.cta_primary }}</a>
            <a class="lss__btn lss__btn--ghost" href="/pages/guia-de-tamanho">{{ section.settings.cta_secondary }}</a>
          </div>
        {%- endif -%}
      </div>
    </section>
  {%- endfor -%}
</div>

<style>
  #lume-ss-{{ section.id }} {
    --ss-ink: #2D2D2D; --ss-dark: #181818; --ss-cream: #F7F3EC;
    --ss-gold: #C9A97A; --ss-beige: #E7D0B1;
    background: var(--ss-beige);
    color: var(--ss-ink);
    font-family: "Inter", system-ui, -apple-system, sans-serif;
  }
  #lume-ss-{{ section.id }} * { box-sizing: border-box; }

  /* ---------- estrutura: mobile-first (empilhado) ---------- */
  #lume-ss-{{ section.id }} .lss__ch {
    display: flex; flex-direction: column;
    background: var(--ss-beige);
  }
  #lume-ss-{{ section.id }} .lss__media {
    position: relative; width: 100%;
    aspect-ratio: 4 / 5; overflow: hidden;
  }
  #lume-ss-{{ section.id }} .lss__media img {
    width: 100%; height: 100%; object-fit: cover; display: block;
  }
  #lume-ss-{{ section.id }} .lss__copy {
    text-align: center;
    padding: 30px clamp(20px, 6vw, 48px) clamp(56px, 10vh, 90px);
    max-width: 46rem; margin: 0 auto;
  }
  #lume-ss-{{ section.id }} .lss__kicker {
    font-size: .72rem; letter-spacing: .22em; text-transform: uppercase;
    color: var(--ss-gold); font-weight: 600; margin: 0 0 14px;
  }
  #lume-ss-{{ section.id }} .lss__title {
    font-family: "Instrument Serif", "Times New Roman", serif; font-weight: 400;
    font-size: clamp(2rem, 8vw, 3.4rem); line-height: 1.05;
    margin: 0 0 16px; color: var(--ss-dark); text-wrap: balance;
  }
  #lume-ss-{{ section.id }} .lss__text {
    font-size: clamp(1rem, 1.5vw, 1.15rem); line-height: 1.6;
    color: rgba(45,45,45,.78); margin: 0 auto; max-width: 42ch;
  }
  #lume-ss-{{ section.id }} .lss__cta {
    display: flex; flex-wrap: wrap; gap: 12px; justify-content: center; margin-top: 32px;
  }
  #lume-ss-{{ section.id }} .lss__btn {
    display: inline-flex; align-items: center; justify-content: center;
    min-height: 48px; padding: 0 1.8em; border-radius: 999px;
    font-weight: 600; font-size: .98rem; text-decoration: none;
    border: 1px solid transparent; transition: background .25s, border-color .25s;
  }
  #lume-ss-{{ section.id }} .lss__btn--solid { background: var(--ss-dark); color: var(--ss-cream); }
  #lume-ss-{{ section.id }} .lss__btn--ghost { border-color: rgba(45,45,45,.4); color: var(--ss-ink); }

  /* ---------- desktop: lado a lado ---------- */
  @media (min-width: 750px) {
    #lume-ss-{{ section.id }} .lss__ch {
      flex-direction: row; align-items: center;
      min-height: 100svh; gap: clamp(28px, 5vw, 72px);
      padding: 0 clamp(28px, 5vw, 80px);
      max-width: 1500px; margin: 0 auto;
    }
    #lume-ss-{{ section.id }} .lss__ch:nth-child(even) { flex-direction: row-reverse; }
    #lume-ss-{{ section.id }} .lss__media {
      flex: 1 1 55%; aspect-ratio: 16 / 10; border-radius: 24px;
    }
    #lume-ss-{{ section.id }} .lss__copy {
      flex: 1 1 45%; text-align: left; padding: 0; margin: 0;
    }
    #lume-ss-{{ section.id }} .lss__text { margin: 0; }
    #lume-ss-{{ section.id }} .lss__cta { justify-content: flex-start; }
    #lume-ss-{{ section.id }} .lss__title { font-size: clamp(2.4rem, 3.6vw, 4rem); }
  }

  /* ---------- CAMADA 3 · fallback (estado oculto só com JS vivo) ---------- */
  #lume-ss-{{ section.id }}.lss--anim .lss__media img,
  #lume-ss-{{ section.id }}.lss--anim .lss__copy > * {
    opacity: 0; transform: translateY(24px);
  }
  #lume-ss-{{ section.id }} .lss-in .lss__media img,
  #lume-ss-{{ section.id }} .lss-in .lss__copy > * {
    opacity: 1; transform: none;
    transition: opacity .7s cubic-bezier(.22,1,.36,1), transform .7s cubic-bezier(.22,1,.36,1);
  }
  #lume-ss-{{ section.id }} .lss-in .lss__copy > *:nth-child(2) { transition-delay: .08s; }
  #lume-ss-{{ section.id }} .lss-in .lss__copy > *:nth-child(3) { transition-delay: .16s; }
  #lume-ss-{{ section.id }} .lss-in .lss__copy > *:nth-child(4) { transition-delay: .24s; }

  /* ---------- CAMADA 1 · MOBILE: CSS scroll-driven nativo ---------- */
  @supports (animation-timeline: view()) {
    @media (max-width: 749px) {
      /* o scroll dirige de verdade: sem JS, roda no compositor */
      #lume-ss-{{ section.id }}.lss--anim .lss__media img,
      #lume-ss-{{ section.id }}.lss--anim .lss__copy > * { opacity: 1; transform: none; }

      #lume-ss-{{ section.id }} .lss__media img {
        animation: lss-media linear both;
        animation-timeline: view();
        animation-range: entry 0% cover 55%;
      }
      #lume-ss-{{ section.id }} .lss__copy > * {
        animation: lss-rise linear both;
        animation-timeline: view();
        animation-range: entry 8% cover 42%;
      }
      @keyframes lss-media {
        from { opacity: .35; transform: scale(1.08); }
        to   { opacity: 1;   transform: scale(1); }
      }
      @keyframes lss-rise {
        from { opacity: 0; transform: translateY(26px); }
        to   { opacity: 1; transform: none; }
      }
    }
  }

  /* ---------- CAMADA 0 · reduced motion vence tudo ---------- */
  @media (prefers-reduced-motion: reduce) {
    #lume-ss-{{ section.id }} .lss__media img,
    #lume-ss-{{ section.id }} .lss__copy > * {
      opacity: 1 !important; transform: none !important;
      animation: none !important; transition: none !important;
    }
  }
</style>

<script>
(function () {
  var root = document.getElementById('lume-ss-{{ section.id }}');
  if (!root || root.dataset.init) return;
  root.dataset.init = '1';

  var guards = window.__lssGuards || {};
  if (guards['{{ section.id }}']) clearTimeout(guards['{{ section.id }}']);

  var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (reduce) { root.classList.remove('lss--anim'); return; }

  var chapters = Array.prototype.slice.call(root.querySelectorAll('.lss__ch'));
  var isMobile = window.matchMedia('(max-width: 749px)').matches;
  var nativeTimeline = CSS && CSS.supports && CSS.supports('animation-timeline: view()');

  // CAMADA 1 — mobile com scroll-driven nativo: o CSS já cuida de tudo.
  if (isMobile && nativeTimeline) return;

  function scroller() {
    var pw = document.querySelector('.page-wrapper');
    if (pw && pw.scrollHeight > pw.clientHeight + 40) return pw;
    return null; // window
  }

  // CAMADA 2 — desktop com GSAP + ScrollTrigger
  function initGSAP() {
    var gsap = window.gsap, ST = window.ScrollTrigger;
    if (!gsap || !ST) return false;
    gsap.registerPlugin(ST);
    var sc = scroller();
    if (sc) ST.defaults({ scroller: sc });

    chapters.forEach(function (ch) {
      var img = ch.querySelector('.lss__media img');
      var bits = ch.querySelectorAll('.lss__copy > *');
      var tl = { trigger: ch, start: 'top 78%', once: true };

      gsap.fromTo(img, { opacity: 0, scale: 1.06 },
        { opacity: 1, scale: 1, duration: 1.1, ease: 'power3.out', scrollTrigger: tl });
      gsap.fromTo(bits, { opacity: 0, y: 26 },
        { opacity: 1, y: 0, duration: .9, stagger: .08, ease: 'power3.out', scrollTrigger: tl });

      // parallax leve só no desktop
      gsap.fromTo(img, { yPercent: -3 }, {
        yPercent: 3, ease: 'none',
        scrollTrigger: { trigger: ch, start: 'top bottom', end: 'bottom top', scrub: true }
      });
    });

    root.classList.remove('lss--anim');
    window.addEventListener('load', function () { ST.refresh(); });
    [300, 1200].forEach(function (t) { setTimeout(function () { ST.refresh(); }, t); });
    return true;
  }

  // CAMADA 3 — fallback IntersectionObserver
  function initIO() {
    if (!('IntersectionObserver' in window)) { root.classList.remove('lss--anim'); return; }
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) {
        if (!e.isIntersecting) return;
        e.target.classList.add('lss-in');
        io.unobserve(e.target);
      });
    }, { threshold: 0.15, rootMargin: '0px 0px -6% 0px' });
    chapters.forEach(function (ch) { io.observe(ch); });
    // rede extra: se o IO não disparar em 2.5s, revela tudo
    setTimeout(function () {
      if (!root.querySelector('.lss-in')) root.classList.remove('lss--anim');
    }, 2500);
  }

  var tries = 0;
  (function waitGSAP() {
    if (initGSAP()) return;
    if (++tries > 60) { initIO(); return; }
    requestAnimationFrame(waitGSAP);
  })();
})();
</script>

{% schema %}
{
  "name": "Lume Scroll Story",
  "tag": "section",
  "settings": [
    { "type": "url", "id": "buy_url", "label": "Link de compra" },
    { "type": "text", "id": "cta_primary", "label": "CTA principal", "default": "Comprar Lume Ring" },
    { "type": "text", "id": "cta_secondary", "label": "CTA secundário", "default": "Descubra seu tamanho" },

    { "type": "header", "content": "1 · Material" },
    { "type": "text", "id": "k1_kicker", "label": "Sobretítulo", "default": "Titânio grau 5" },
    { "type": "text", "id": "k1_title", "label": "Título", "default": "Três gramas no seu dedo." },
    { "type": "textarea", "id": "k1_text", "label": "Texto", "default": "Titânio aeroespacial com acabamento espelhado. Resistente a riscos, hipoalergênico, à prova d'água até 100 metros." },

    { "type": "header", "content": "2 · Sensores" },
    { "type": "text", "id": "k2_kicker", "label": "Sobretítulo", "default": "Engenharia invisível" },
    { "type": "text", "id": "k2_title", "label": "Título", "default": "Sensores que não aparecem." },
    { "type": "textarea", "id": "k2_text", "label": "Texto", "default": "Frequência cardíaca, variabilidade, oxigenação, temperatura e movimento — medidos sem você perceber." },

    { "type": "header", "content": "3 · Sono" },
    { "type": "text", "id": "k3_kicker", "label": "Sobretítulo", "default": "Sono" },
    { "type": "text", "id": "k3_title", "label": "Título", "default": "Noites melhores. Dias melhores." },
    { "type": "textarea", "id": "k3_text", "label": "Texto", "default": "Cada estágio da noite medido com precisão e traduzido em um único número claro ao acordar." },

    { "type": "header", "content": "4 · 24 horas" },
    { "type": "text", "id": "k4_kicker", "label": "Sobretítulo", "default": "Monitoramento contínuo" },
    { "type": "text", "id": "k4_title", "label": "Título", "default": "Seu corpo, 24 horas por dia." },
    { "type": "textarea", "id": "k4_text", "label": "Texto", "default": "Da primeira hora do sono ao fim do treino. Sem telas, sem notificações, sem ruído." },

    { "type": "header", "content": "5 · Bateria" },
    { "type": "text", "id": "k5_kicker", "label": "Sobretítulo", "default": "Autonomia" },
    { "type": "text", "id": "k5_title", "label": "Título", "default": "Uma semana longe da tomada." },
    { "type": "textarea", "id": "k5_text", "label": "Texto", "default": "Até 7 dias por carga. A recarga completa leva cerca de 90 minutos na base magnética inclusa." },

    { "type": "header", "content": "6 · Acabamentos" },
    { "type": "text", "id": "k6_kicker", "label": "Sobretítulo", "default": "Três acabamentos" },
    { "type": "text", "id": "k6_title", "label": "Título", "default": "Escolha o seu." },
    { "type": "textarea", "id": "k6_text", "label": "Texto", "default": "Preto Fosco, Prata Titânio e Dourado. O mesmo anel, o mesmo desempenho — o acabamento é seu." }
  ],
  "presets": [{ "name": "Lume Scroll Story", "category": "Lume" }]
}
{% endschema %}
