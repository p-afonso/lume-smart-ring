{{ 'lume-ring.css' | asset_url | stylesheet_tag }}

{%- comment -%}
  LUME RING — homepage v2 (cinematic scrollytelling)
  Every media block has an image_picker + a graceful fallback
  (verified stock photo or brand-toned placeholder). When the
  Gravyx renders are generated they slot in via the theme editor
  with zero code changes.
{%- endcomment -%}
{%- assign ph_hero = 'https://images.unsplash.com/photo-1651752090085-50375d90bf8b?auto=format&fit=crop&w=2400&h=1400&q=80' -%}
{%- assign ph_pin = 'https://images.unsplash.com/photo-1651752090085-50375d90bf8b?auto=format&fit=crop&w=1800&h=1800&crop=entropy&q=85' -%}
{%- assign ph_metal = 'https://images.unsplash.com/photo-1656055448548-e26753307fc7?auto=format&fit=crop&w=1600&h=1200&q=80' -%}
{%- assign ph_dark = 'https://images.unsplash.com/photo-1611572705535-e4d6cd9a12cb?auto=format&fit=crop&w=2400&h=1200&q=80' -%}

{%- assign buy = section.settings.buy_url | default: '/products/lume-smart-ring' -%}

<div id="lume-ring">
<script>
  /* Reveal state before first paint (no flash); watchdog guarantees
     content is never left hidden if lume-ring.js fails to boot. */
  (function () {
    var r = document.getElementById('lume-ring');
    if (!r) return;
    if (!('IntersectionObserver' in window)) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    r.classList.add('anim');
    window.__lrGuard = setTimeout(function () { r.classList.remove('anim'); }, 3000);
  })();
</script>

  {%- comment -%} ===== 1 · HERO ===== {%- endcomment -%}
  <section class="lr-hero">
    <div class="lr-media lr-hero__media">
      {%- if section.settings.hero_image -%}
        {{ section.settings.hero_image | image_url: width: 2400 | image_tag: alt: 'Anel Lume em titânio sobre superfície escura', loading: 'eager', fetchpriority: 'high' }}
      {%- else -%}
        <img src="{{ 'lume-hero.jpg' | asset_url }}" alt="Coleção de anéis Lume em titânio — dourado, prata, preto e grafite" loading="eager" fetchpriority="high" width="1916" height="821">
      {%- endif -%}
    </div>
    <div class="lr-hero__scrim"></div>
    <div class="lr-hero__in">
      <p class="lr-eyebrow lr-hero__eyebrow lr-r">{{ section.settings.hero_eyebrow }}</p>
      <h1 class="lr-display lr-hero__title lr-r lr-r-d1">{{ section.settings.hero_title }}</h1>
      <p class="lr-hero__sub lr-r lr-r-d2">{{ section.settings.hero_sub }}</p>
      <div class="lr-hero__cta lr-r lr-r-d3">
        <a href="{{ buy }}" class="lr-btn lr-btn--cream">{{ section.settings.hero_cta }}</a>
        <a href="{{ buy }}" class="lr-btn lr-btn--ghost-l">{{ section.settings.hero_cta2 }}</a>
      </div>
    </div>
    <div class="lr-hero__cue" aria-hidden="true"><span></span></div>
  </section>

