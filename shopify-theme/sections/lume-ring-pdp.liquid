  "name": "Lume Ring — PDP",
  "tag": "section",
  "settings": [
    { "type": "header", "content": "Parcelamento" },
    { "type": "paragraph", "content": "Só ative se o seu gateway realmente oferecer parcelamento sem juros — anunciar condição que não existe é propaganda enganosa." },
    { "type": "checkbox", "id": "show_installments", "label": "Exibir parcelamento", "default": false },
    { "type": "range", "id": "installments", "label": "Número de parcelas", "min": 2, "max": 12, "step": 1, "default": 4 }
  ],
  "presets": [{ "name": "Lume Ring — PDP", "category": "Lume" }]
}
{% endschema %}
