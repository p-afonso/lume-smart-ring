{%- comment -%}
  LUME RING — página de vendas (PDP).

  Preço, variantes e disponibilidade vêm SEMPRE do objeto `product`.
  Nada de valor hardcoded: se o preço mudar no admin, a página segue.

  O produto tem só a opção "Acabamento" (3 cores). O TAMANHO é enviado
  como line item property, já que não existe variante de tamanho —
  assim o pedido registra qual tamanho o cliente escolheu sem precisar
  de 21 variantes.
{%- endcomment -%}

{%- assign v = product.selected_or_first_available_variant -%}

<div id="pdp-{{ section.id }}" class="pdp">

  {%- comment -%} ===== 1 · HERO / COMPRA ===== {%- endcomment -%}
  <section class="pdp__hero">
    <div class="pdp__gallery">
      {%- for media in product.media limit: 6 -%}
        <div class="pdp__shot{% if forloop.first %} is-on{% endif %}" data-shot="{{ forloop.index0 }}">
          {{ media | image_url: width: 1400 | image_tag:
             alt: media.alt | default: product.title,
             loading: 'lazy',
             widths: '500, 800, 1200, 1400',
             sizes: '(max-width: 749px) 100vw, 55vw' }}
        </div>
      {%- else -%}
        <div class="pdp__shot is-on">{{ 'product-1' | placeholder_svg_tag: 'pdp__ph' }}</div>
      {%- endfor -%}
    </div>

    <div class="pdp__panel">
      <div class="pdp__card">
        <h1 class="pdp__title">{{ product.title }}</h1>

        <div class="pdp__row pdp__row--price">
          <div class="pdp__price" data-price>
            <strong>{{ v.price | money }}</strong>
            {%- if v.compare_at_price and v.compare_at_price > v.price -%}
              <s>{{ v.compare_at_price | money }}</s>
            {%- endif -%}
          </div>
          {%- if section.settings.show_installments and section.settings.installments > 1 -%}
            {%- assign parcela = v.price | divided_by: section.settings.installments -%}
            <p class="pdp__inst">ou {{ section.settings.installments }}× de <strong>{{ parcela | money }}</strong> · sem juros</p>
          {%- endif -%}
        </div>

        <form action="/cart/add" method="post" enctype="multipart/form-data" data-pdp-form>
          <input type="hidden" name="id" value="{{ v.id }}" data-variant-id>

          {%- for option in product.options_with_values -%}
            <div class="pdp__row">
              <span class="pdp__rowLabel">{{ option.name | upcase }}</span>
              <div class="pdp__dots" role="radiogroup" aria-label="{{ option.name }}">
                {%- for value in option.values -%}
                  <button type="button" class="pdp__dot{% if value == v.title %} is-on{% endif %}"
                          role="radio" aria-checked="{% if value == v.title %}true{% else %}false{% endif %}"
                          data-opt-value="{{ value | escape }}" aria-label="{{ value | escape }}" title="{{ value | escape }}">
                    <i data-tone="{{ value | handle }}"></i>
                  </button>
                {%- endfor -%}
              </div>
            </div>
          {%- endfor -%}

          <div class="pdp__row">
            <span class="pdp__rowLabel">TAMANHO</span>
            <div class="pdp__sizes" role="radiogroup" aria-label="Tamanho">
              {%- assign sizes = '7,8,9,10,11,12,13' | split: ',' -%}
              {%- for s in sizes -%}
                <button type="button" class="pdp__size" role="radio" aria-checked="false" data-size="{{ s }}">{{ s }}</button>
              {%- endfor -%}
            </div>
          </div>

          <input type="hidden" name="properties[Tamanho]" data-size-input>
          <p class="pdp__warn" data-size-warn hidden>Escolha um tamanho para continuar.</p>

          <button type="button" class="pdp__sizeGuide" data-open-size>
            <svg viewBox="0 0 24 24" width="17" height="17" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true"><rect x="2" y="8" width="20" height="8" rx="2"/><path d="M6 8v3M10 8v4M14 8v3M18 8v4"/></svg>
            Descubra seu tamanho
            <svg class="pdp__chev" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
          </button>

          <button type="submit" class="pdp__cta" data-add>
            <span>{% if v.available %}Adicionar ao carrinho{% else %}Esgotado{% endif %}</span>
            <svg viewBox="0 0 24 24" width="19" height="19" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true"><circle cx="9" cy="20" r="1.4"/><circle cx="18" cy="20" r="1.4"/><path d="M2 3h3l2.4 12h11.2L21 7H6"/></svg>
          </button>
        </form>
      </div>

      {%- comment -%} Brinde: base de carregamento. Preço vem do produto real. {%- endcomment -%}
      {%- assign dock = all_products['base-de-carregamento-lume'] -%}
      <div class="pdp__gift">
        <div class="pdp__giftThumb">
          {%- if dock and dock.featured_image -%}
            {{ dock.featured_image | image_url: width: 160 | image_tag: alt: dock.title, loading: 'lazy' }}
          {%- else -%}
            <span class="pdp__giftIcon" aria-hidden="true"></span>
          {%- endif -%}
        </div>
        <div class="pdp__giftText">
          <strong>Base de Carregamento</strong>
          <span>Inclusa na sua compra</span>
        </div>
        <div class="pdp__giftPrice">
          {%- if dock and dock.price > 0 -%}<s>{{ dock.price | money }}</s>{%- endif -%}
          <em>Grátis</em>
        </div>
      </div>

      <ul class="pdp__trust">
        <li>Frete grátis</li>
        <li>30 dias para testar</li>
        <li>Garantia de 12 meses</li>
        <li>Sem assinatura</li>
      </ul>
    </div>
  </section>

  {%- comment -%} ===== 2 · O QUE O LUME MONITORA ===== {%- endcomment -%}
  <section class="pdp__block">
    <h2 class="pdp__h2">Tudo que o Lume acompanha.</h2>
    <div class="pdp__grid">
      <article class="pdp__card"><h3>Frequência cardíaca</h3><p>Leitura contínua, 24 horas por dia, sem você perceber.</p></article>
      <article class="pdp__card"><h3>Sono</h3><p>Estágios REM, leve e profundo, com um score claro ao acordar.</p></article>
      <article class="pdp__card"><h3>Atividade</h3><p>Passos, calorias e treinos detectados automaticamente.</p></article>
      <article class="pdp__card"><h3>Oxigenação (SpO2)</h3><p>Saturação de oxigênio no sangue medida durante a noite.</p></article>
      <article class="pdp__card"><h3>Temperatura de pele</h3><p>Tendências que revelam sinais antes de você sentir.</p></article>
      <article class="pdp__card"><h3>HRV e estresse</h3><p>A variabilidade cardíaca traduzida em prontidão diária.</p></article>
    </div>
  </section>

  {%- comment -%} ===== 3 · RESISTÊNCIA ===== {%- endcomment -%}
  <section class="pdp__wide">
    <video class="pdp__wideMedia" muted loop playsinline preload="none"
           poster="{{ 'lume-ss-1.jpg' | asset_url }}" data-pdp-video>
      <source data-src="{{ 'lume-ss-1.mp4' | asset_url }}" type="video/mp4">
    </video>
    <div class="pdp__wideCopy">
      <p class="pdp__kicker">Resistência</p>
      <h2 class="pdp__h2">IP68. À prova d'água até 100 metros.</h2>
      <p class="pdp__lead">Banho, piscina e mar sem preocupação. Titânio grau 5, hipoalergênico, a partir de 3 gramas.</p>
    </div>
  </section>

  {%- comment -%} ===== 4 · O APP ===== {%- endcomment -%}
  <section class="pdp__block pdp__block--app">
    <div>
      <p class="pdp__kicker">Aplicativo</p>
      <h2 class="pdp__h2">Seus dados, com clareza.</h2>
      <p class="pdp__lead">Milhares de leituras viram três números simples: Sono, Prontidão e Atividade. Sem assinatura — todos os recursos inclusos para sempre.</p>
      <div class="pdp__apps">
        <a class="pdp__appBtn" href="https://apps.apple.com/br/app/qring/id6473672621" target="_blank" rel="noopener">App Store</a>
        <a class="pdp__appBtn" href="https://play.google.com/store/search?q=qring&amp;c=apps&amp;hl=pt_BR" target="_blank" rel="noopener">Google Play</a>
      </div>
      <p class="pdp__fine">Compatível com iOS 13+ e Android 8+.</p>
    </div>
    <div class="pdp__scores">
      <div class="pdp__score"><span>Sono</span><strong>92</strong></div>
      <div class="pdp__score"><span>Prontidão</span><strong>88</strong></div>
      <div class="pdp__score"><span>Atividade</span><strong>75</strong></div>
    </div>
  </section>

  {%- comment -%} ===== 5 · DIFERENCIAIS ===== {%- endcomment -%}
  <section class="pdp__block">
    <div class="pdp__cols">
      <div><h3>Sensores discretos</h3><p>Toda a tecnologia por dentro. Por fora, só um anel — confortável o suficiente para usar 24 horas, inclusive dormindo.</p></div>
      <div><h3>Titânio grau 5</h3><p>A partir de 3 gramas, hipoalergênico e resistente a riscos. Feito para não sair do dedo.</p></div>
      <div><h3>Até 7 dias de bateria</h3><p>Uma carga por semana. A recarga completa leva cerca de 90 minutos na base magnética inclusa.</p></div>
    </div>
  </section>

  {%- comment -%} ===== 6 · COMPARATIVO (apenas atributos próprios) ===== {%- endcomment -%}
  <section class="pdp__block">
    <h2 class="pdp__h2">O que está incluso.</h2>
    <table class="pdp__table">
      <tbody>
        <tr><td>Sem assinatura mensal</td><td class="yes">Incluso</td></tr>
        <tr><td>Base de carregamento magnética</td><td class="yes">Na caixa</td></tr>
        <tr><td>Kit de medição de tamanho</td><td class="yes">Na caixa</td></tr>
        <tr><td>Bateria</td><td class="yes">Até 7 dias</td></tr>
        <tr><td>Resistência à água</td><td class="yes">IP68 · 100 m</td></tr>
        <tr><td>Compatibilidade</td><td class="yes">iOS 13+ e Android 8+</td></tr>
        <tr><td>Frete para todo o Brasil</td><td class="yes">Grátis</td></tr>
        <tr><td>Garantia</td><td class="yes">12 meses</td></tr>
        <tr><td>Período de teste</td><td class="yes">30 dias</td></tr>
      </tbody>
    </table>
  </section>

  {%- comment -%} ===== 7 · FAQ ===== {%- endcomment -%}
  <section class="pdp__block">
    <h2 class="pdp__h2">Perguntas frequentes</h2>
    <div class="pdp__faq">
      <details><summary>O que é o Lume Ring?</summary><p>Um anel inteligente em titânio que acompanha sono, frequência cardíaca, variabilidade, oxigenação, temperatura e atividade 24 horas por dia — sem telas e sem notificações.</p></details>
      <details><summary>Como descubro o tamanho certo?</summary><p>Use a nossa ferramenta de medição: você calibra a tela com um cartão de banco e ajusta um círculo até encaixar no seu anel. <a href="/pages/guia-de-tamanho">Abrir o guia de tamanho</a>. Um kit de medição também acompanha a compra.</p></details>
      <details><summary>Em qual dedo devo usar?</summary><p>Indicador, médio ou anelar, preferencialmente da mão não dominante — a leitura fica mais estável.</p></details>
      <details><summary>O que vem na caixa?</summary><p>O anel, a base de carregamento magnética e o kit de medição de tamanho.</p></details>
      <details><summary>Como acompanho meus dados?</summary><p>Pelo aplicativo, que sincroniza automaticamente por Bluetooth e resume tudo em scores de 0 a 100.</p></details>
      <details><summary>Quais aparelhos são compatíveis?</summary><p>iOS 13 ou superior e Android 8 ou superior.</p></details>
      <details><summary>Preciso pagar assinatura?</summary><p>Não. Todos os recursos do app são inclusos para sempre.</p></details>
    </div>
  </section>

  {%- comment -%} ===== 8 · CTA FINAL ===== {%- endcomment -%}
  <section class="pdp__final">
    <h2 class="pdp__h2">Comece hoje.</h2>
    <p class="pdp__finalPrice" data-price-echo>{{ v.price | money }}</p>
    <button type="button" class="pdp__cta pdp__cta--wide" data-scroll-top>Escolher meu Lume Ring</button>
    <p class="pdp__fine">Frete grátis · 30 dias para testar · Garantia de 12 meses</p>
  </section>

  {%- comment -%} CTA fixo no mobile {%- endcomment -%}
  <div class="pdp__sticky" data-sticky hidden>
    <span data-price-sticky>{{ v.price | money }}</span>
    <button type="button" class="pdp__cta" data-scroll-top>Adicionar ao carrinho</button>
  </div>

  {%- comment -%} Modal de tamanho {%- endcomment -%}
  <dialog class="pdp__modal" data-size-modal>
    <h3>Tabela de tamanhos</h3>
    <table class="pdp__sizeTable">
      <thead><tr><th>Tam.</th><th>Circunferência</th><th>Diâmetro</th></tr></thead>
      <tbody>
        <tr><td>7</td><td>53,6 mm</td><td>17,1 mm</td></tr>
        <tr><td>8</td><td>55,9 mm</td><td>17,8 mm</td></tr>
        <tr><td>9</td><td>58,8 mm</td><td>18,7 mm</td></tr>
        <tr><td>10</td><td>61,2 mm</td><td>19,5 mm</td></tr>
        <tr><td>11</td><td>64,0 mm</td><td>20,4 mm</td></tr>
        <tr><td>12</td><td>66,3 mm</td><td>21,1 mm</td></tr>
        <tr><td>13</td><td>69,0 mm</td><td>22,0 mm</td></tr>
      </tbody>
    </table>
    <p class="pdp__fine">Quer medir com precisão? A ferramenta calibra a tela do seu aparelho com um cartão de banco.</p>
    <a class="pdp__cta pdp__cta--wide" href="/pages/guia-de-tamanho">Abrir ferramenta de medição</a>
    <button type="button" class="pdp__modalClose" data-close-size>Fechar</button>
  </dialog>

  <script type="application/json" data-variants>
    {{ product.variants | json }}
  </script>
</div>

<style>
  #pdp-{{ section.id }} {
    --p-ink: #2D2D2D; --p-dark: #181818; --p-cream: #F7F3EC;
    --p-gold: #C9A97A; --p-beige: #E7D0B1; --p-line: #e5ddd0;
    --p-accent: #1B6EF3;
    background: #fff; color: var(--p-ink);
    font-family: "Inter", system-ui, -apple-system, sans-serif;
  }
  #pdp-{{ section.id }} * { box-sizing: border-box; }
  #pdp-{{ section.id }} img, #pdp-{{ section.id }} video { max-width: 100%; display: block; }

  #pdp-{{ section.id }} .pdp__h2 {
    font-family: "Instrument Serif", "Times New Roman", serif; font-weight: 400;
    font-size: clamp(1.9rem, 4.6vw, 3rem); line-height: 1.06;
    margin: 0 0 18px; color: var(--p-dark); text-wrap: balance;
  }
  #pdp-{{ section.id }} .pdp__kicker {
    font-size: .72rem; letter-spacing: .22em; text-transform: uppercase;
    color: var(--p-gold); font-weight: 600; margin: 0 0 10px;
  }
  #pdp-{{ section.id }} .pdp__lead { font-size: 1.05rem; line-height: 1.6; color: rgba(45,45,45,.8); margin: 0; max-width: 46ch; }
  #pdp-{{ section.id }} .pdp__fine { font-size: .82rem; color: rgba(45,45,45,.62); margin: 12px 0 0; }

  /* ---- HERO (layout de referência: galeria clara + card branco) ---- */
  #pdp-{{ section.id }} .pdp__hero {
    display: grid; gap: 20px;
    padding: 0 0 clamp(24px, 4vw, 48px);
    background: #fff;
  }
  #pdp-{{ section.id }} .pdp__gallery {
    position: relative; overflow: hidden;
    background: linear-gradient(160deg,#f4f4f5,#e9e9ea);
    aspect-ratio: 1 / 1;
  }
  #pdp-{{ section.id }} .pdp__shot { position: absolute; inset: 0; opacity: 0; transition: opacity .4s ease; }
  #pdp-{{ section.id }} .pdp__shot.is-on { opacity: 1; }
  #pdp-{{ section.id }} .pdp__shot img { width: 100%; height: 100%; object-fit: cover; }

  #pdp-{{ section.id }} .pdp__panel { display: grid; gap: 14px; padding: 0 clamp(16px, 4vw, 28px); }
  #pdp-{{ section.id }} .pdp__card {
    background: #fff; border: 1px solid #ececed; border-radius: 22px;
    padding: clamp(22px, 3.4vw, 34px);
    box-shadow: 0 1px 2px rgba(0,0,0,.04);
  }
  #pdp-{{ section.id }} .pdp__title {
    font-family: "Instrument Serif", "Times New Roman", serif; font-weight: 400;
    font-size: clamp(2.1rem, 5vw, 3.1rem); line-height: 1.04;
    margin: 0 0 4px; color: #111; letter-spacing: -.01em;
  }

  /* linhas com rótulo à esquerda e controle à direita, separadas por hairline */
  #pdp-{{ section.id }} .pdp__row {
    display: flex; align-items: center; justify-content: space-between;
    gap: 16px; flex-wrap: wrap;
    padding: 18px 0; border-top: 1px solid #ececed;
  }
  #pdp-{{ section.id }} .pdp__row--price { display: block; }
  #pdp-{{ section.id }} .pdp__rowLabel {
    font-size: .74rem; letter-spacing: .14em; font-weight: 600; color: #8b8b90;
  }

  #pdp-{{ section.id }} .pdp__price { display: flex; align-items: baseline; gap: 12px; }
  #pdp-{{ section.id }} .pdp__price strong { font-size: clamp(1.9rem, 4vw, 2.5rem); font-weight: 700; color: #111; letter-spacing: -.02em; }
  #pdp-{{ section.id }} .pdp__price s { color: #9a9aa0; font-size: 1.05rem; }
  #pdp-{{ section.id }} .pdp__inst { margin: 6px 0 0; font-size: .95rem; color: #6b6b70; }
  #pdp-{{ section.id }} .pdp__inst strong { color: #111; font-weight: 600; }

  /* cor: só bolinhas */
  #pdp-{{ section.id }} .pdp__dots { display: flex; gap: 10px; }
  #pdp-{{ section.id }} .pdp__dot {
    width: 34px; height: 34px; padding: 0; border-radius: 50%;
    border: 2px solid transparent; background: none; cursor: pointer;
    display: grid; place-items: center; transition: border-color .18s;
  }
  #pdp-{{ section.id }} .pdp__dot i {
    width: 26px; height: 26px; border-radius: 50%; display: block;
    box-shadow: inset 0 0 0 1px rgba(0,0,0,.12);
  }
  #pdp-{{ section.id }} .pdp__dot.is-on { border-color: #111; }
  #pdp-{{ section.id }} .pdp__dot i[data-tone="preto-fosco"] { background: linear-gradient(145deg,#3a3a3d,#101012); }
  #pdp-{{ section.id }} .pdp__dot i[data-tone="prata-titanio"] { background: linear-gradient(145deg,#eeeef2,#b9b9c0); }
  #pdp-{{ section.id }} .pdp__dot i[data-tone="dourado"] { background: linear-gradient(145deg,#f3d9a6,#c79a4e); }

  /* tamanho: pílulas compactas */
  #pdp-{{ section.id }} .pdp__sizes { display: flex; gap: 6px; flex-wrap: wrap; }
  #pdp-{{ section.id }} .pdp__size {
    width: 44px; height: 44px; padding: 0;
    border: 1px solid #e3e3e5; border-radius: 14px; background: #fff;
    font: inherit; font-size: .95rem; font-weight: 500; color: #111;
    cursor: pointer; transition: all .16s;
  }
  #pdp-{{ section.id }} .pdp__size:hover { border-color: #c9c9cd; }
  #pdp-{{ section.id }} .pdp__size.is-on { background: #111; color: #fff; border-color: #111; font-weight: 600; }
  #pdp-{{ section.id }} .pdp__warn { color: #c0392b; font-size: .85rem; margin: 10px 0 0; }

  /* botão do guia de tamanho: largura total, contornado */
  #pdp-{{ section.id }} .pdp__sizeGuide {
    display: flex; align-items: center; justify-content: center; gap: 8px;
    width: 100%; min-height: 52px; margin: 18px 0 12px;
    border: 1px solid #e3e3e5; border-radius: 999px; background: #fff;
    font: inherit; font-size: .95rem; color: #111; cursor: pointer;
    transition: border-color .18s;
  }
  #pdp-{{ section.id }} .pdp__sizeGuide:hover { border-color: #111; }
  #pdp-{{ section.id }} .pdp__chev { margin-left: 2px; color: #9a9aa0; }

  /* CTA principal */
  #pdp-{{ section.id }} .pdp__cta {
    display: flex; align-items: center; justify-content: center; gap: 10px;
    width: 100%; min-height: 58px; padding: 0 2em; border: 0;
    border-radius: 999px; background: var(--p-accent); color: #fff;
    font: inherit; font-weight: 600; font-size: 1.02rem; cursor: pointer;
    text-decoration: none; transition: filter .18s;
  }
  #pdp-{{ section.id }} .pdp__cta:hover { filter: brightness(1.07); }
  #pdp-{{ section.id }} .pdp__cta[disabled] { background: #c9c9cd; cursor: not-allowed; }
  #pdp-{{ section.id }} .pdp__cta--wide { max-width: 380px; margin: 0 auto; }

  /* card do brinde */
  #pdp-{{ section.id }} .pdp__gift {
    display: flex; align-items: center; gap: 14px;
    background: #fff; border: 1px solid #ececed; border-radius: 18px;
    padding: 14px 18px;
  }
  #pdp-{{ section.id }} .pdp__giftThumb {
    width: 54px; height: 54px; flex: none; border-radius: 12px;
    background: linear-gradient(150deg,#3a3a3d,#141416);
    display: grid; place-items: center; overflow: hidden;
  }
  #pdp-{{ section.id }} .pdp__giftThumb img { width: 100%; height: 100%; object-fit: cover; }
  #pdp-{{ section.id }} .pdp__giftText { flex: 1; min-width: 0; }
  #pdp-{{ section.id }} .pdp__giftText strong { display: block; font-size: .98rem; color: #111; }
  #pdp-{{ section.id }} .pdp__giftText span { font-size: .86rem; color: #8b8b90; }
  #pdp-{{ section.id }} .pdp__giftPrice { text-align: right; flex: none; }
  #pdp-{{ section.id }} .pdp__giftPrice s { display: block; font-size: .82rem; color: #9a9aa0; }
  #pdp-{{ section.id }} .pdp__giftPrice em {
    display: inline-block; margin-top: 4px; font-style: normal; font-weight: 600;
    font-size: .8rem; color: #1a7f4b; background: #e7f6ee;
    padding: .25em .8em; border-radius: 999px;
  }

  #pdp-{{ section.id }} .pdp__trust {
    list-style: none; display: flex; flex-wrap: wrap; gap: 8px 18px;
    padding: 0 4px; margin: 4px 0 0; font-size: .86rem; color: #6b6b70;
  }
  #pdp-{{ section.id }} .pdp__trust li::before { content: "✓ "; color: var(--p-accent); }

  /* ---- blocos ---- */
  #pdp-{{ section.id }} .pdp__block { padding: clamp(48px, 8vh, 96px) clamp(20px, 5vw, 56px); max-width: 1200px; margin: 0 auto; }
  #pdp-{{ section.id }} .pdp__grid { display: grid; gap: 16px; grid-template-columns: 1fr; }
  #pdp-{{ section.id }} .pdp__card { background: #fff; border: 1px solid var(--p-line); border-radius: 18px; padding: 22px; }
  #pdp-{{ section.id }} .pdp__card h3 { margin: 0 0 8px; font-size: 1.05rem; color: var(--p-dark); }
  #pdp-{{ section.id }} .pdp__card p { margin: 0; font-size: .92rem; color: rgba(45,45,45,.75); line-height: 1.55; }

  #pdp-{{ section.id }} .pdp__wide { position: relative; }
  #pdp-{{ section.id }} .pdp__wideMedia { width: 100%; height: clamp(280px, 52vh, 560px); object-fit: cover; }
  #pdp-{{ section.id }} .pdp__wideCopy { padding: clamp(28px, 5vw, 56px); max-width: 1200px; margin: 0 auto; }

  #pdp-{{ section.id }} .pdp__block--app { display: grid; gap: 32px; }
  #pdp-{{ section.id }} .pdp__apps { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 22px; }
  #pdp-{{ section.id }} .pdp__appBtn {
    display: inline-flex; align-items: center; min-height: 48px; padding: 0 1.4em;
    border: 1px solid var(--p-line); border-radius: 12px; background: #fff;
    color: var(--p-dark); text-decoration: none; font-weight: 600; font-size: .92rem;
  }
  #pdp-{{ section.id }} .pdp__scores { display: flex; gap: 12px; flex-wrap: wrap; }
  #pdp-{{ section.id }} .pdp__score { flex: 1 1 120px; background: #fff; border: 1px solid var(--p-line); border-radius: 18px; padding: 20px; text-align: center; }
  #pdp-{{ section.id }} .pdp__score span { display: block; font-size: .72rem; letter-spacing: .14em; text-transform: uppercase; color: rgba(45,45,45,.6); margin-bottom: 6px; }
  #pdp-{{ section.id }} .pdp__score strong { font-family: "Instrument Serif", serif; font-weight: 400; font-size: 2.4rem; color: var(--p-dark); }

  #pdp-{{ section.id }} .pdp__cols { display: grid; gap: 28px; }
  #pdp-{{ section.id }} .pdp__cols h3 { font-family: "Instrument Serif", serif; font-weight: 400; font-size: 1.5rem; margin: 0 0 8px; color: var(--p-dark); }
  #pdp-{{ section.id }} .pdp__cols p { margin: 0; color: rgba(45,45,45,.75); line-height: 1.6; }

  #pdp-{{ section.id }} .pdp__table { width: 100%; border-collapse: collapse; }
  #pdp-{{ section.id }} .pdp__table td { padding: 14px 12px; border-bottom: 1px solid var(--p-line); }
  #pdp-{{ section.id }} .pdp__table td.yes { text-align: right; font-weight: 600; color: var(--p-dark); }

  #pdp-{{ section.id }} .pdp__faq details { border-bottom: 1px solid var(--p-line); }
  #pdp-{{ section.id }} .pdp__faq summary { cursor: pointer; padding: 18px 0; font-weight: 600; color: var(--p-dark); list-style: none; }
  #pdp-{{ section.id }} .pdp__faq summary::-webkit-details-marker { display: none; }
  #pdp-{{ section.id }} .pdp__faq summary::after { content: "+"; float: right; color: var(--p-gold); }
  #pdp-{{ section.id }} .pdp__faq details[open] summary::after { content: "−"; }
  #pdp-{{ section.id }} .pdp__faq p { margin: 0 0 18px; color: rgba(45,45,45,.78); line-height: 1.6; }

  #pdp-{{ section.id }} .pdp__final { text-align: center; padding: clamp(56px, 9vh, 110px) clamp(20px, 5vw, 56px); background: var(--p-beige); }
  #pdp-{{ section.id }} .pdp__finalPrice { font-size: 1.5rem; font-weight: 600; color: var(--p-dark); margin: 0 0 22px; }

  /* CTA fixo no mobile */
  #pdp-{{ section.id }} .pdp__sticky {
    position: fixed; left: 0; right: 0; bottom: 0; z-index: 40;
    display: flex; align-items: center; gap: 12px;
    padding: 10px 16px calc(10px + env(safe-area-inset-bottom));
    background: rgba(247,243,236,.96); backdrop-filter: blur(10px);
    border-top: 1px solid var(--p-line);
  }
  #pdp-{{ section.id }} .pdp__sticky span { font-weight: 600; color: var(--p-dark); white-space: nowrap; }
  #pdp-{{ section.id }} .pdp__sticky .pdp__cta { min-height: 48px; }
  @media (min-width: 750px) { #pdp-{{ section.id }} .pdp__sticky { display: none !important; } }

  /* modal */
  #pdp-{{ section.id }} .pdp__modal { border: 0; border-radius: 20px; padding: 26px; max-width: 460px; width: calc(100% - 32px); color: var(--p-ink); }
  #pdp-{{ section.id }} .pdp__modal::backdrop { background: rgba(24,24,24,.55); }
  #pdp-{{ section.id }} .pdp__modal h3 { font-family: "Instrument Serif", serif; font-weight: 400; font-size: 1.5rem; margin: 0 0 14px; color: var(--p-dark); }
  #pdp-{{ section.id }} .pdp__sizeTable { width: 100%; border-collapse: collapse; margin-bottom: 16px; }
  #pdp-{{ section.id }} .pdp__sizeTable th { text-align: left; font-size: .7rem; letter-spacing: .12em; text-transform: uppercase; color: rgba(45,45,45,.6); padding: 8px; }
  #pdp-{{ section.id }} .pdp__sizeTable td { padding: 8px; border-top: 1px solid var(--p-line); }
  #pdp-{{ section.id }} .pdp__modalClose { display: block; width: 100%; margin-top: 12px; min-height: 44px; border: 1px solid var(--p-line); border-radius: 999px; background: #fff; font: inherit; cursor: pointer; }

  /* ---- desktop ---- */
  @media (min-width: 750px) {
    #pdp-{{ section.id }} .pdp__hero { grid-template-columns: 1.15fr .85fr; align-items: start; gap: 28px; padding: 0 clamp(16px,3vw,32px) clamp(32px,5vh,64px); }
    #pdp-{{ section.id }} .pdp__gallery { border-radius: 22px; aspect-ratio: 4/5; }
    #pdp-{{ section.id }} .pdp__panel { position: sticky; top: 96px; padding: 0; }
    #pdp-{{ section.id }} .pdp__grid { grid-template-columns: repeat(3, 1fr); }
    #pdp-{{ section.id }} .pdp__cols { grid-template-columns: repeat(3, 1fr); gap: 40px; }
    #pdp-{{ section.id }} .pdp__block--app { grid-template-columns: 1.1fr .9fr; align-items: center; }
    #pdp-{{ section.id }} .pdp__cta--wide { width: auto; min-width: 280px; }
    #pdp-{{ section.id }} .pdp__wideCopy { position: absolute; inset: auto 0 0 0; color: var(--p-cream); background: linear-gradient(180deg, transparent, rgba(24,24,24,.75)); }
    #pdp-{{ section.id }} .pdp__wideCopy .pdp__h2 { color: #fff; }
    #pdp-{{ section.id }} .pdp__wideCopy .pdp__lead { color: rgba(247,243,236,.9); }
  }

  @media (prefers-reduced-motion: reduce) {
    #pdp-{{ section.id }} .pdp__shot { transition: none; }
  }
</style>

<script>
(function () {
  var root = document.getElementById('pdp-{{ section.id }}');
  if (!root || root.dataset.init) return;
  root.dataset.init = '1';

  var variants = [];
  try { variants = JSON.parse(root.querySelector('[data-variants]').textContent); } catch (e) {}

  var form      = root.querySelector('[data-pdp-form]');
  var idInput   = root.querySelector('[data-variant-id]');
  var sizeInput = root.querySelector('[data-size-input]');
  var sizeWarn  = root.querySelector('[data-size-warn]');
  var addBtn    = root.querySelector('[data-add]');
  var shots     = Array.prototype.slice.call(root.querySelectorAll('.pdp__shot'));
  var priceEls  = Array.prototype.slice.call(root.querySelectorAll('[data-price] strong, [data-price-echo], [data-price-sticky]'));

  function money(cents) {
    return 'R$ ' + (cents / 100).toFixed(2).replace('.', ',').replace(/\B(?=(\d{3})+(?!\d))/g, '.');
  }

  /* ---- cor: troca variante, preço e foto ---- */
  root.querySelectorAll('[data-opt-value]').forEach(function (btn, idx) {
    btn.addEventListener('click', function () {
      root.querySelectorAll('[data-opt-value]').forEach(function (b) {
        b.classList.remove('is-on'); b.setAttribute('aria-checked', 'false');
      });
      btn.classList.add('is-on'); btn.setAttribute('aria-checked', 'true');

      var val = btn.dataset.optValue;
      var match = variants.filter(function (v) { return v.title === val; })[0];
      if (match) {
        idInput.value = match.id;
        priceEls.forEach(function (el) { el.textContent = money(match.price); });
        addBtn.textContent = match.available ? 'Adicionar ao carrinho' : 'Esgotado';
        addBtn.disabled = !match.available;
      }
      // a galeria segue a ordem das cores
      shots.forEach(function (s, i) { s.classList.toggle('is-on', i === idx); });
    });
  });

  /* ---- tamanho: line item property ---- */
  root.querySelectorAll('[data-size]').forEach(function (btn) {
    btn.addEventListener('click', function () {
      root.querySelectorAll('[data-size]').forEach(function (b) {
        b.classList.remove('is-on'); b.setAttribute('aria-checked', 'false');
      });
      btn.classList.add('is-on'); btn.setAttribute('aria-checked', 'true');
      sizeInput.value = btn.dataset.size;
      sizeWarn.hidden = true;
    });
  });

  form.addEventListener('submit', function (e) {
    if (!sizeInput.value) {
      e.preventDefault();
      sizeWarn.hidden = false;
      root.querySelector('.pdp__sizes').scrollIntoView({ block: 'center' });
    }
  });

  /* ---- modal de tamanho ---- */
  var modal = root.querySelector('[data-size-modal]');
  root.querySelector('[data-open-size]').addEventListener('click', function () {
    if (modal.showModal) modal.showModal();
    else window.location.href = '/pages/guia-de-tamanho';
  });
  root.querySelector('[data-close-size]').addEventListener('click', function () { modal.close(); });
  modal.addEventListener('click', function (e) { if (e.target === modal) modal.close(); });

  /* ---- CTA fixo no mobile: aparece ao sair do hero ---- */
  var sticky = root.querySelector('[data-sticky]');
  var hero = root.querySelector('.pdp__hero');
  if ('IntersectionObserver' in window) {
    new IntersectionObserver(function (entries) {
      entries.forEach(function (en) { sticky.hidden = en.isIntersecting; });
    }, { threshold: 0.15 }).observe(hero);
  }
  root.querySelectorAll('[data-scroll-top]').forEach(function (b) {
    b.addEventListener('click', function () { hero.scrollIntoView({ behavior: 'smooth', block: 'start' }); });
  });

  /* ---- vídeo da faixa de resistência: carrega e toca ao entrar ---- */
  var vid = root.querySelector('[data-pdp-video]');
  if (vid && 'IntersectionObserver' in window) {
    new IntersectionObserver(function (entries) {
      entries.forEach(function (en) {
        if (!en.isIntersecting) { if (!vid.paused) vid.pause(); return; }
        var s = vid.querySelector('source[data-src]');
        if (s && !s.src) { s.src = s.dataset.src; vid.load(); }
        var p = vid.play(); if (p && p.catch) p.catch(function () {});
      });
    }, { threshold: 0.25 }).observe(vid);
  }
})();
</script>

