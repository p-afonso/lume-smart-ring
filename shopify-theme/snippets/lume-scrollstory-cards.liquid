      if (!r) return;
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
      r.classList.add('lss--anim');
      window.__lssGuard = setTimeout(function () { r.classList.remove('lss--anim'); }, 3000);
    })();
