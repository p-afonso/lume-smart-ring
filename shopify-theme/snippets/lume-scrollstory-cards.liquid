{%- comment -%}
  LUME — História de scroll cinematográfica (pinned + scrub).

  PALCO fixo (position: sticky) segura os clipes empilhados. O texto de
  cada capítulo rola POR CIMA. O SCROLL DIRIGE O VÍDEO: a posição da
  rolagem define o currentTime do clipe — rolar pra baixo avança o
  quadro, rolar pra cima volta. Nada de loop automático.

  PARAMETRIZÁVEL: aceita `chapters` (ex.: "1,2") para renderizar só um
  trecho da história, permitindo intercalar outras seções entre os
  capítulos. Cada instância vira um palco sticky independente.

  Uso:
    {% render 'lume-scrollstory-cards', buy: buy, chapters: '1,2' %}
    ... outra seção ...
    {% render 'lume-scrollstory-cards', buy: buy, chapters: '3,4', with_assets: true %}

  - sticky é CSS puro -> o pin nunca depende de JS
  - scrub com throttle por TEMPO (flag booleana pode emperrar)
  - só o clipe ativo (e o próximo) são baixados
  - sem JS -> primeiro clipe + todos os textos visíveis
  - prefers-reduced-motion -> só os posters, sem scrub
{%- endcomment -%}

{%- assign ss_buy = buy | default: '/products/lume-smart-ring' -%}
{%- assign ss_chapters = chapters | default: '1,2,3,4' -%}
{%- assign ss_list = ss_chapters | split: ',' -%}
{%- comment -%} cor de moldura de cada clipe, amostrada do 1º quadro {%- endcomment -%}
{%- assign ss_bg = '#988976,#e0d0ba,#22110b,#d2bda4' | split: ',' -%}

<div class="lss" data-lss>
  {%- comment -%} PALCO FIXO — só os clipes deste trecho {%- endcomment -%}
  <div class="lss__stage" aria-hidden="true">
    {%- for n in ss_list -%}
      {%- assign i = n | plus: 0 -%}
      {%- assign bgi = i | minus: 1 -%}
      <div class="lss__layer{% if forloop.first %} is-on{% endif %}" data-layer="{{ i }}"
           style="background: {{ ss_bg[bgi] }}">
        <video class="lss__video" data-lss-video
               muted playsinline preload="none"
               poster="{{ 'lume-ss-' | append: i | append: '.jpg' | asset_url }}"
               width="1280" height="716">
          <source data-src="{{ 'lume-ss-' | append: i | append: '.mp4' | asset_url }}" type="video/mp4">
        </video>
      </div>
    {%- endfor -%}
    <div class="lss__scrim"></div>
  </div>

  {%- comment -%} TRILHA — o texto rola por cima do palco {%- endcomment -%}
  <div class="lss__track">
    {%- for n in ss_list -%}
      {%- assign i = n | plus: 0 -%}
      <section class="lss__step{% if forloop.last %} lss__step--last{% endif %}" data-step="{{ forloop.index }}">
        <div class="lss__cap">
          {%- case i -%}
            {%- when 1 -%}
              <p class="lss__kicker">Titânio grau 5</p>
              <h2 class="lss__title">Três gramas no seu dedo.</h2>
              <p class="lss__text">Titânio aeroespacial com acabamento espelhado. Resistente a riscos, hipoalergênico, à prova d'água até 100 metros.</p>
              <div class="lss__chips">
                <span class="lss__chip">Titânio grau 5</span>
                <span class="lss__chip">100 m</span>
                <span class="lss__chip">IP68</span>
                <span class="lss__chip">3 g</span>
                <span class="lss__chip">Hipoalergênico</span>
              </div>
            {%- when 2 -%}
              <p class="lss__kicker">Engenharia invisível</p>
              <h2 class="lss__title">Sensores que não aparecem.</h2>
              <p class="lss__text">Frequência cardíaca, variabilidade, oxigenação, temperatura e movimento — medidos sem você perceber.</p>
            {%- when 3 -%}
              <p class="lss__kicker">Sono</p>
              <h2 class="lss__title">Noites melhores. Dias melhores.</h2>
              <p class="lss__text">Cada estágio da noite medido com precisão e traduzido em um único número claro ao acordar.</p>
            {%- when 4 -%}
              <p class="lss__kicker">Monitoramento contínuo</p>
              <h2 class="lss__title">Seu corpo, 24 horas por dia.</h2>
              <p class="lss__text">Da primeira hora do sono ao fim do treino. Sem telas, sem notificações, sem ruído.</p>
              <div class="lss__cta">
                <a class="lss__btn lss__btn--solid" href="{{ ss_buy }}">Comprar Lume Ring</a>
                <a class="lss__btn lss__btn--ghost" href="/pages/guia-de-tamanho">Descubra seu tamanho</a>
              </div>
          {%- endcase -%}
        </div>
      </section>
    {%- endfor -%}
  </div>
</div>

{%- comment -%}
  CSS e JS saem só uma vez. Como {% render %} isola o escopo, quem chama
  passa with_assets: true na ÚLTIMA instância — assim o script roda depois
  de todos os [data-lss] existirem no DOM e inicializa todos de uma vez.
{%- endcomment -%}
{%- if with_assets -%}
<style>
  .lss {
    --ss-ink: #2D2D2D; --ss-dark: #181818; --ss-cream: #F7F3EC;
    --ss-gold: #C9A97A; --ss-beige: #E7D0B1;
    position: relative;
    background: var(--ss-dark);
    font-family: "Inter", system-ui, -apple-system, sans-serif;
  }
  .lss * { box-sizing: border-box; }

  /* ---------- PALCO FIXO ---------- */
  .lss__stage {
    position: sticky; top: 0;
    height: 100svh; width: 100%;
    overflow: hidden;
    margin-bottom: -100svh;   /* puxa a trilha para sobrepor o palco */
    z-index: 0;
  }
  .lss__layer {
    position: absolute; inset: 0;
    opacity: 0; transition: opacity .8s cubic-bezier(.4,0,.2,1);
  }
  .lss__layer.is-on { opacity: 1; }
  .lss__layer video { width: 100%; height: 100%; object-fit: cover; display: block; }

  .lss__scrim {
    position: absolute; inset: 0; pointer-events: none;
    background: linear-gradient(180deg,
      rgba(24,24,24,.45) 0%, rgba(24,24,24,0) 28%,
      rgba(24,24,24,0) 45%, rgba(24,24,24,.78) 100%);
  }

  /* ---------- TRILHA (texto rolando por cima) ---------- */
  .lss__track { position: relative; z-index: 1; }
  .lss__step {
    min-height: 88svh;
    display: flex; align-items: flex-end;
    padding: 0 clamp(20px, 5vw, 72px) clamp(48px, 9vh, 96px);
  }
  .lss__step--last { min-height: 100svh; }

  .lss__cap {
    max-width: 34rem; color: var(--ss-cream);
    opacity: 0; transform: translateY(28px);
    transition: opacity .7s cubic-bezier(.22,1,.36,1), transform .7s cubic-bezier(.22,1,.36,1);
  }
  .lss__step.is-on .lss__cap { opacity: 1; transform: none; }
  .lss:not([data-init]) .lss__cap { opacity: 1; transform: none; }

  .lss__kicker {
    font-size: .72rem; letter-spacing: .22em; text-transform: uppercase;
    color: var(--ss-gold); font-weight: 600; margin: 0 0 12px;
  }
  .lss__title {
    font-family: "Instrument Serif", "Times New Roman", serif; font-weight: 400;
    font-size: clamp(2.1rem, 6vw, 4rem); line-height: 1.04;
    margin: 0 0 14px; color: #fff; text-wrap: balance;
    text-shadow: 0 2px 24px rgba(0,0,0,.35);
  }
  .lss__text {
    font-size: clamp(1rem, 1.5vw, 1.15rem); line-height: 1.6;
    color: rgba(247,243,236,.9); margin: 0; max-width: 40ch;
    text-shadow: 0 1px 16px rgba(0,0,0,.4);
  }
  .lss__chips { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 20px; }
  .lss__chip {
    border: 1px solid rgba(247,243,236,.4); border-radius: 999px;
    padding: .45em 1em; font-size: .78rem; color: rgba(247,243,236,.92);
  }
  .lss__cta { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 28px; }
  .lss__btn {
    display: inline-flex; align-items: center; justify-content: center;
    min-height: 48px; padding: 0 1.8em; border-radius: 999px;
    font-weight: 600; font-size: .98rem; text-decoration: none;
    border: 1px solid transparent; transition: background .25s, border-color .25s;
  }
  .lss__btn--solid { background: var(--ss-cream); color: var(--ss-dark); }
  .lss__btn--ghost { border-color: rgba(247,243,236,.55); color: var(--ss-cream); }
  .lss__btn--ghost:hover { background: rgba(247,243,236,.12); }

  /* ---------- MOBILE: quadro inteiro do clipe ----------
     16:9 numa tela ~9:19: com "cover" as laterais eram cortadas e a
     composição sumia. Com "contain" o quadro aparece inteiro e a
     moldura usa a cor da própria cena. */
  @media (max-width: 749px) {
    .lss__layer video { object-fit: contain; object-position: center 30%; }
    .lss__scrim {
      background: linear-gradient(180deg,
        rgba(24,24,24,.30) 0%, rgba(24,24,24,0) 18%,
        rgba(24,24,24,0) 34%, rgba(24,24,24,.55) 62%, rgba(24,24,24,.88) 100%);
    }
  }

  @media (min-width: 750px) {
    .lss__cap { max-width: 38rem; }
    .lss__step { padding-bottom: clamp(64px, 11vh, 120px); }
  }

  @media (prefers-reduced-motion: reduce) {
    .lss__layer { transition: none; }
    .lss__cap { opacity: 1 !important; transform: none !important; transition: none !important; }
  }
</style>

<script>
/* Inicializa TODAS as instâncias de [data-lss]. Cada uma é um palco
   independente, com seu próprio conjunto de clipes e seu próprio scrub. */
(function () {
  var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  function initOne(root) {
    if (root.dataset.init) return;

    var layers = Array.prototype.slice.call(root.querySelectorAll('.lss__layer'));
    var steps  = Array.prototype.slice.call(root.querySelectorAll('.lss__step'));
    var vids   = layers.map(function (l) { return l.querySelector('video'); });

    if (reduce) { steps.forEach(function (s) { s.classList.add('is-on'); }); return; }
    root.dataset.init = '1';

    function loadVideo(v) {
      if (!v || v.dataset.loaded) return;
      v.dataset.loaded = '1';
      var s = v.querySelector('source[data-src]');
      if (s && !s.src) {
        s.src = s.dataset.src; v.preload = 'auto'; v.load();
        // a duração só existe depois dos metadados; sem isso o primeiro
        // update() retorna cedo e o clipe fica parado no quadro 0
        v.addEventListener('loadedmetadata', onScroll, { once: true });
        v.addEventListener('canplay', onScroll, { once: true });
      }
    }

    var active = -1;
    function setActive(i) {
      if (i === active) return;
      active = i;
      layers.forEach(function (l, k) { l.classList.toggle('is-on', k === i); });
      steps.forEach(function (s, k) { if (k <= i) s.classList.add('is-on'); });
      loadVideo(vids[i]);
      loadVideo(vids[i + 1]);
    }

    function update() {
      var vh = window.innerHeight || document.documentElement.clientHeight;
      var best = 0, bestDist = Infinity;
      for (var i = 0; i < steps.length; i++) {
        var r = steps[i].getBoundingClientRect();
        var d = Math.abs((r.top + r.height / 2) - vh / 2);
        if (d < bestDist) { bestDist = d; best = i; }
      }
      setActive(best);

      var step = steps[best], v = vids[best];
      if (!v || !v.duration || !isFinite(v.duration)) return;

      var rect = step.getBoundingClientRect();
      var p = (vh - rect.top) / (rect.height + vh);
      p = p < 0 ? 0 : (p > 1 ? 1 : p);

      var t = p * (v.duration - 0.06);
      if (Math.abs(v.currentTime - t) > 0.02 && !v.seeking) {
        try { v.currentTime = t; } catch (e) {}
      }
    }

    /* Throttle por TEMPO, não por flag booleana.
       Com rAF + flag, se um frame não vier (aba oculta, aba em segundo
       plano, throttling do navegador), a flag fica presa em true e a
       rolagem para de mexer no vídeo para sempre. */
    var lastRun = 0;
    function onScroll() {
      var now = (window.performance && performance.now) ? performance.now() : Date.now();
      if (now - lastRun < 16) return;
      lastRun = now;
      try { update(); } catch (e) {}
    }

    var pw = document.querySelector('.page-wrapper');
    var target = (pw && pw.scrollHeight > pw.clientHeight + 40) ? pw : window;
    target.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll);

    setTimeout(function () {
      if (!root.querySelector('.lss__step.is-on')) {
        steps.forEach(function (s) { s.classList.add('is-on'); });
      }
    }, 2500);

    loadVideo(vids[0]);
    setActive(0);
    update();
  }

  Array.prototype.slice.call(document.querySelectorAll('[data-lss]')).forEach(initOne);
})();
</script>
{%- endif -%}
