{%- comment -%}
  LUME — História de scroll cinematográfica (pinned scrollytelling).

  Estrutura: um PALCO fixo (position: sticky) segura os 6 vídeos empilhados,
  que fazem crossfade entre si. O texto de cada capítulo rola POR CIMA do
  vídeo. Resultado: o vídeo acompanha a rolagem, em vez de a página virar
  uma pilha de blocos de tela cheia.

  - sticky é CSS puro -> "o vídeo acompanha o scroll" nunca depende de JS
  - troca de capítulo via IntersectionObserver + transição CSS
  - cada vídeo carrega e toca só quando é o capítulo ativo; pausa ao sair
  - sem IO / sem JS -> primeiro vídeo + todos os textos visíveis
  - prefers-reduced-motion -> só os posters, sem autoplay
{%- endcomment -%}

{%- assign ss_buy = buy | default: '/products/lume-smart-ring' -%}

<div class="lss" data-lss>
  {%- comment -%} PALCO FIXO — os 6 vídeos empilhados {%- endcomment -%}
  <div class="lss__stage" aria-hidden="true">
    {%- for i in (1..6) -%}
      <div class="lss__layer{% if forloop.first %} is-on{% endif %}" data-layer="{{ i }}">
        <video class="lss__video" data-lss-video
               muted loop playsinline preload="none"
               poster="{{ 'lume-ss-' | append: i | append: '.jpg' | asset_url }}"
               width="1280" height="716">
          <source data-src="{{ 'lume-ss-' | append: i | append: '.mp4' | asset_url }}" type="video/mp4">
        </video>
      </div>
    {%- endfor -%}
    <div class="lss__scrim"></div>
  </div>

  {%- comment -%} TRILHA — o texto rola por cima do palco {%- endcomment -%}
  <div class="lss__track">

    <section class="lss__step" data-step="1">
      <div class="lss__cap">
        <p class="lss__kicker">Titânio grau 5</p>
        <h2 class="lss__title">Três gramas no seu dedo.</h2>
        <p class="lss__text">Titânio aeroespacial com acabamento espelhado. Resistente a riscos, hipoalergênico, à prova d'água até 100 metros.</p>
        <div class="lss__chips">
          <span class="lss__chip">Titânio grau 5</span>
          <span class="lss__chip">100 m</span>
          <span class="lss__chip">IP68</span>
          <span class="lss__chip">3 g</span>
          <span class="lss__chip">Hipoalergênico</span>
        </div>
      </div>
    </section>

    <section class="lss__step" data-step="2">
      <div class="lss__cap">
        <p class="lss__kicker">Engenharia invisível</p>
        <h2 class="lss__title">Sensores que não aparecem.</h2>
        <p class="lss__text">Frequência cardíaca, variabilidade, oxigenação, temperatura e movimento — medidos sem você perceber.</p>
      </div>
    </section>

    <section class="lss__step" data-step="3">
      <div class="lss__cap">
        <p class="lss__kicker">Sono</p>
        <h2 class="lss__title">Noites melhores. Dias melhores.</h2>
        <p class="lss__text">Cada estágio da noite medido com precisão e traduzido em um único número claro ao acordar.</p>
      </div>
    </section>

    <section class="lss__step" data-step="4">
      <div class="lss__cap">
        <p class="lss__kicker">Monitoramento contínuo</p>
        <h2 class="lss__title">Seu corpo, 24 horas por dia.</h2>
        <p class="lss__text">Da primeira hora do sono ao fim do treino. Sem telas, sem notificações, sem ruído.</p>
      </div>
    </section>

    <section class="lss__step" data-step="5">
      <div class="lss__cap">
        <p class="lss__kicker">Autonomia</p>
        <h2 class="lss__title">Uma semana longe da tomada.</h2>
        <p class="lss__text">Até 7 dias por carga. A recarga completa leva cerca de 90 minutos na base magnética inclusa.</p>
      </div>
    </section>

    <section class="lss__step lss__step--last" data-step="6">
      <div class="lss__cap">
        <p class="lss__kicker">Três acabamentos</p>
        <h2 class="lss__title">Escolha o seu.</h2>
        <p class="lss__text">Preto Fosco, Prata Titânio e Dourado. O mesmo anel, o mesmo desempenho — o acabamento é seu.</p>
        <div class="lss__cta">
          <a class="lss__btn lss__btn--solid" href="{{ ss_buy }}">Comprar Lume Ring</a>
          <a class="lss__btn lss__btn--ghost" href="/pages/guia-de-tamanho">Descubra seu tamanho</a>
        </div>
      </div>
    </section>

  </div>
</div>

<style>
  .lss {
    --ss-ink: #2D2D2D; --ss-dark: #181818; --ss-cream: #F7F3EC;
    --ss-gold: #C9A97A; --ss-beige: #E7D0B1;
    position: relative;
    background: var(--ss-dark);
    font-family: "Inter", system-ui, -apple-system, sans-serif;
  }
  .lss * { box-sizing: border-box; }

  /* ---------- PALCO FIXO ---------- */
  .lss__stage {
    position: sticky; top: 0;
    height: 100svh; width: 100%;
    overflow: hidden;
    margin-bottom: -100svh;   /* puxa a trilha para sobrepor o palco */
    z-index: 0;
  }
  .lss__layer {
    position: absolute; inset: 0;
    opacity: 0; transition: opacity .9s cubic-bezier(.4,0,.2,1);
  }
  .lss__layer.is-on { opacity: 1; }
  .lss__layer video { width: 100%; height: 100%; object-fit: cover; display: block; }

  /* scrim para o texto ficar legível sobre qualquer quadro */
  .lss__scrim {
    position: absolute; inset: 0; pointer-events: none;
    background: linear-gradient(180deg,
      rgba(24,24,24,.45) 0%, rgba(24,24,24,0) 28%,
      rgba(24,24,24,0) 45%, rgba(24,24,24,.78) 100%);
  }

  /* ---------- TRILHA (texto rolando por cima) ---------- */
  .lss__track { position: relative; z-index: 1; }
  .lss__step {
    min-height: 88svh;
    display: flex; align-items: flex-end;
    padding: 0 clamp(20px, 5vw, 72px) clamp(48px, 9vh, 96px);
  }
  .lss__step--last { min-height: 100svh; }

  .lss__cap {
    max-width: 34rem; color: var(--ss-cream);
    opacity: 0; transform: translateY(28px);
    transition: opacity .7s cubic-bezier(.22,1,.36,1), transform .7s cubic-bezier(.22,1,.36,1);
  }
  .lss__step.is-on .lss__cap { opacity: 1; transform: none; }
  /* sem JS: tudo visível */
  .lss:not([data-init]) .lss__cap { opacity: 1; transform: none; }

  .lss__kicker {
    font-size: .72rem; letter-spacing: .22em; text-transform: uppercase;
    color: var(--ss-gold); font-weight: 600; margin: 0 0 12px;
  }
  .lss__title {
    font-family: "Instrument Serif", "Times New Roman", serif; font-weight: 400;
    font-size: clamp(2.1rem, 6vw, 4rem); line-height: 1.04;
    margin: 0 0 14px; color: #fff; text-wrap: balance;
    text-shadow: 0 2px 24px rgba(0,0,0,.35);
  }
  .lss__text {
    font-size: clamp(1rem, 1.5vw, 1.15rem); line-height: 1.6;
    color: rgba(247,243,236,.9); margin: 0; max-width: 40ch;
    text-shadow: 0 1px 16px rgba(0,0,0,.4);
  }
  .lss__chips { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 20px; }
  .lss__chip {
    border: 1px solid rgba(247,243,236,.4); border-radius: 999px;
    padding: .45em 1em; font-size: .78rem; color: rgba(247,243,236,.92);
  }
  .lss__cta { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 28px; }
  .lss__btn {
    display: inline-flex; align-items: center; justify-content: center;
    min-height: 48px; padding: 0 1.8em; border-radius: 999px;
    font-weight: 600; font-size: .98rem; text-decoration: none;
    border: 1px solid transparent; transition: background .25s, border-color .25s;
  }
  .lss__btn--solid { background: var(--ss-cream); color: var(--ss-dark); }
  .lss__btn--ghost { border-color: rgba(247,243,236,.55); color: var(--ss-cream); }
  .lss__btn--ghost:hover { background: rgba(247,243,236,.12); }

  @media (min-width: 750px) {
    .lss__cap { max-width: 38rem; }
    .lss__step { padding-bottom: clamp(64px, 11vh, 120px); }
  }

  @media (prefers-reduced-motion: reduce) {
    .lss__layer { transition: none; }
    .lss__cap { opacity: 1 !important; transform: none !important; transition: none !important; }
  }
</style>

<script>
(function () {
  var root = document.querySelector('[data-lss]');
  if (!root || root.dataset.init) return;

  var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  var layers = Array.prototype.slice.call(root.querySelectorAll('.lss__layer'));
  var steps  = Array.prototype.slice.call(root.querySelectorAll('.lss__step'));
  var vids   = Array.prototype.slice.call(root.querySelectorAll('[data-lss-video]'));

  function loadVideo(v) {
    if (!v || v.dataset.loaded) return;
    v.dataset.loaded = '1';
    var s = v.querySelector('source[data-src]');
    if (s && !s.src) { s.src = s.dataset.src; v.load(); }
  }

  function play(v) {
    if (!v || reduce) return;
    loadVideo(v);
    var p = v.play(); if (p && p.catch) p.catch(function () {});
  }

  function activate(idx) {
    layers.forEach(function (l, i) {
      var on = (i === idx);
      l.classList.toggle('is-on', on);
      var v = l.querySelector('video');
      if (!v || reduce) return;
      if (on) play(v);
      else if (!v.paused) v.pause();
    });
    // pré-carrega o próximo para a troca não piscar
    if (layers[idx + 1] && !reduce) loadVideo(layers[idx + 1].querySelector('video'));
  }

  function revealAll() {
    steps.forEach(function (s) { s.classList.add('is-on'); });
    play(vids[0]);
  }

  if (!('IntersectionObserver' in window)) { revealAll(); return; }

  root.dataset.init = '1';

  var io = new IntersectionObserver(function (entries) {
    entries.forEach(function (e) {
      if (!e.isIntersecting) return;
      e.target.classList.add('is-on');
      activate(parseInt(e.target.dataset.step, 10) - 1);
    });
  }, { threshold: 0.5 });
  steps.forEach(function (s) { io.observe(s); });

  // rede de segurança: se o IO não disparar, revela tudo
  setTimeout(function () {
    if (!root.querySelector('.lss__step.is-on')) revealAll();
  }, 2500);

  activate(0);
})();
</script>
